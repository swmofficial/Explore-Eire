# Supabase Configuration
# VITE_ prefix exposes variables to the client bundle - use only for public keys
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - NEVER prefix with VITE_ as it bypasses RLS
# Used only in server-side scripts (e.g., seedCourses.js)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe Configuration (server-side only - no VITE_ prefix)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe public key (safe for client)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here